# Frontend, public — baked into the bundle at build time.
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=

# Backend secrets — kept in .env (gitignored).
POSTGRES_PASSWORD=

# Server-only secrets live in `.env.api` (gitignored, mounted into the
# api container via env_file). Required keys:
#
#   ANTHROPIC_API_KEY=sk-ant-...
#   VOYAGE_API_KEY=pa-...
#   EXA_API_KEY=...
#   GOOGLE_OAUTH_CLIENT_ID=...
#   GOOGLE_OAUTH_CLIENT_SECRET=...
#   JWT_SECRET=<run `openssl rand -hex 32`>
#   PUBLIC_BASE_URL=https://dutch-atlas.com  # used to build OAuth redirect URI
