# Google Maps JavaScript API key.
# Get one at https://console.cloud.google.com/apis/credentials
# Restrict to your domain (HTTP referrers) and the Maps JavaScript API only.
VITE_GOOGLE_MAPS_API_KEY=

# PocketBase URL.
# Default `/pb` works for both dev (Vite proxies /pb → localhost:8090)
# and prod (host nginx proxies /pb → pb container). Override only if you
# want to point the SDK at a different host.
# VITE_POCKETBASE_URL=/pb
